# HTML files — `no-store` is the strongest tier (no-cache only forbids
# *using* a cached copy without revalidation, but mobile Chrome / Samsung
# Internet sometimes treat that as a soft hint and serve stale anyway).
# Combined with the inline build-check that every page now ships with
# (compares baked-in build version to /build.json), a stale page should
# self-heal within one fetch. See docs in scripts/bump-cache.sh.
/*.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

/games/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# /build.json is the lighthouse the inline build-check fetches on every
# pageload. MUST always hit origin so a freshly-deployed version
# is visible immediately. no-store + no-cache + max-age=0 closes every
# loophole including mobile vendors' aggressive cache layers.
/build.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# Shared JS modules — no cache, so edits to killSW/siteFooter/etc. land
# instantly. The `?v=<stamp>` cache-bust query on every reference is
# belt-and-suspenders for vendors that still serve stale.
/js/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# Shared CSS modules (currently just /css/blog-desktop.css). Same
# treatment as /js/* — edits should propagate within one fetch.
/css/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# Blog post manifest — same treatment as /js/* since it's fetched from
# every blog page and a stale copy means stale category routing.
/blog/posts.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# Service Worker - never cache (self-destruct routine must always be latest)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Static assets — short cache (1 day) + must-revalidate.
# Was 1 week, but when the icon artwork swapped (orange → green clover,
# 2026-04-19) existing visitors saw the stale PNG for up to a week and
# PWAs that had been installed kept the old home-screen icon. 1 day +
# must-revalidate means the browser pings the server before using the
# cached copy, so a new bumped `?v=` URL refreshes within 24h without
# blowing out bandwidth for unchanged assets. All new icon references
# already carry a `?v=` query anyway (scripts/bump-icons.sh), so this
# is belt-and-suspenders.
/assets/*
  Cache-Control: public, max-age=86400, must-revalidate

# Per-post OG (Open Graph) images. Filenames include the slug — when a
# post's title or category changes the filename stays the same but the
# PNG body gets regenerated by scripts/generate-og.py. Reddit / X /
# Facebook all cache OG aggressively (their crawlers pin a copy at
# share-time), so a 1-day max-age plus must-revalidate is the right
# balance — long enough that repeat visitors don't re-download the
# image, short enough that author edits propagate within a day.
/og/*
  Cache-Control: public, max-age=86400, must-revalidate

# Audio files — 1 day + must-revalidate (was 7 days).
# 이전 7일 캐시였는데 첫 배포 전 mp3 URL 의 404 응답이 캐시되면
# 7일간 stale HTML 응답이 계속 서빙되는 문제 발생 (테트리스 BGM
# 사례 2026-04-30: track1.mp3 가 Content-Type:text/html 로 서빙
# 되어 audio.error code=4 NotSupportedError). 1일로 단축 +
# must-revalidate 로 재발 시 빨리 회복. 새 mp3 추가/교체 시엔
# URL 에 ?v= 쿼리 붙여서 즉시 cache-miss 강제 권장.
*.mp3
  Cache-Control: public, max-age=86400, must-revalidate

*.wav
  Cache-Control: public, max-age=86400, must-revalidate
